# NoneBot command prefix example
COMMAND_START=["/"]
LOG_LEVEL=INFO

# Kuwo plugin settings
KUWO_SEARCH_LIMIT=5
KUWO_LIST_RENDER_MODE=text
KUWO_TRACK_RENDER_MODE=text  # support: text | card | record | file
KUWO_DEFAULT_QUALITY=standard
KUWO_TRACK_CACHE_RETENTION_DAYS=1  # 0 disables age-based cleanup
KUWO_TRACK_CACHE_MAX_SIZE_MB=1024  # 0 disables size-based cleanup; not recommended below 600MB
